<Page x:Class="IshbulatovGlaza1920.agentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:IshbulatovGlaza1920"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="agentPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Верхняя панель: поиск, сортировка, фильтрация -->
        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left" Grid.Row="0" Grid.ColumnSpan="3">
            <StackPanel Margin="10" Orientation="Horizontal">
                <TextBlock Text="Поиск по наименованию" FontSize="15"/>
                <TextBox Name="TBoxSearch" TextChanged="TBoxSearch_TextChanged" Width="250" FontSize="15"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10">
                <ComboBox Name="ComboSort" SelectionChanged="ComboSort_SelectionChanged" FontSize="15" Width="300">
                    <ComboBoxItem>Сортировка</ComboBoxItem>
                   
                    <ComboBoxItem>Наименование (возр.)</ComboBoxItem>
                    
                    <ComboBoxItem>Наименование (убыв.)</ComboBoxItem>
                   
                    <ComboBoxItem>Скидка (возр.)</ComboBoxItem>
                   
                    <ComboBoxItem>Скидка (убыв.)</ComboBoxItem>
                    
                    <ComboBoxItem>Приоритет (возр.)</ComboBoxItem>
                
                    <ComboBoxItem>Приоритет (убыв.)</ComboBoxItem>
                   
                </ComboBox>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="10">
                <ComboBox Name="ComboType" SelectionChanged="ComboType_SelectionChanged" FontSize="15" Width="150"/>
            </StackPanel>
        </WrapPanel>

        <!-- Список агентов -->
        <ListView Name="ListViewAgent" SelectionMode="Extended" Grid.Row="1" Grid.ColumnSpan="3" 
                  SelectionChanged="ListViewAgent_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Background="{Binding RowColor, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>

                        <!-- Логотип -->
                        <Image Width="100" Height="100" Grid.Column="0" Stretch="Uniform" HorizontalAlignment="Center">
                            <Image.Source>
                                <Binding Path="LogoPath">
                                    <Binding.TargetNullValue>
                                        <ImageSource>/image/picture.png</ImageSource>
                                    </Binding.TargetNullValue>
                                </Binding>
                            </Image.Source>
                        </Image>

                        <!-- Информация об агенте -->
                        <StackPanel Grid.Column="1" Margin="10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding AgentType.Title}" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="|" FontSize="20" Margin="0,0,10,0"/>
                                <TextBlock Text="{Binding Title}" FontSize="20" TextWrapping="Wrap"/>
                            </StackPanel>
                            <TextBlock FontSize="15" Margin="0,5,0,0">
                                <Run Text="Продаж за год: "/>
                                <Run Text="{Binding SalesForYear, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding Phone}" FontSize="15" Margin="0,5,0,0"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Text="Приоритетность: " FontSize="15"/>
                                <TextBlock Text="{Binding Priority}" FontSize="15"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Скидка -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Скидка" FontSize="16" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding Discount, StringFormat={}{0}%, Mode=OneWay}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Кнопка Редактировать -->
                        <Button Grid.Column="3" Name="EditBtn" Click="EditBtn_Click" 
                                Content="Редактировать" VerticalAlignment="Center"
                                Width="100" Height="30"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Нижняя панель -->
        <Button Content="Добавить агента" Name="AddAgent" Click="AddAgent_Click" 
                Grid.Row="2" Grid.Column="0" HorizontalAlignment="Center" FontSize="16" 
                Height="35" Width="200"/>
        <Button Name="ChangePriorityBtn" Content="Изменить приоритет" 
                Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" 
                FontSize="16" Height="35" Width="250"
                Click="ChangePriorityBtn_Click" Visibility="Collapsed"/>
        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="LeftButton" Content="&lt;" Width="30" Height="30" Click="LeftButton_Click"/>
            <ListBox Name="PageListBox" MouseUp="PageListBox_MouseUp" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
            </ListBox>
            <Button Name="RightButton" Content="&gt;" Width="30" Height="30" Click="RightButton_Click"/>
        </StackPanel>
    </Grid>
</Page>