<Window x:Class="IshbulatovGlaza1920.MainWindow"
        WindowState="Maximized"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:IshbulatovGlaza1920"
        mc:Ignorable="d"
        Title="Ишбулатов Глазки" Height="450" Width="800" FontFamily="Century Gothic" Icon="/image/Глазки-save.ico">
    <Grid Background="#FFFFE9F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <Image Source="/image/Глазки-save.ico" HorizontalAlignment="Left" />
        <TextBlock Text="Агентство" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Center"></TextBlock>
        <Frame Name="MainFrame" ContentRendered="MainFrame_ContentRendered" NavigationUIVisibility="Hidden" Grid.Row="1"></Frame>
        <Button Content="Назад" Name="BtnBack" Width="175" Height="30" FontSize="15" Click="BtnBack_Click" HorizontalAlignment="Right" Background="#B175EE" ></Button>
    </Grid>
</Window>
